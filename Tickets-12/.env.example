# Environment variables for Tickets application
# Copy this file to .env and configure your values
# IMPORTANT: Never commit .env with real credentials

# =============================================================================
# PERFILES vs ENTORNOS
# =============================================================================
# PERFIL = archivo de configuración (h2, mysql, supabase)
# ENTORNO = valores de las variables para ese perfil
#
# - Perfil h2  → archivo: application-h2.yml   → entorno: local
# - Perfil mysql → archivo: application-mysql.yml → entorno: dev
# - Perfil supabase → archivo: application-supabase.yml → entornos: test, prod

# =============================================================================
# ENTORNO: LOCAL
# Perfil: h2
# Use for: Development, quick tests, no persistence
# =============================================================================
SPRING_PROFILES_ACTIVE=h2

# MySQL (not used)
# DB_HOST=
# DB_PORT=3306
# DB_NAME=
# DB_USER=
# DB_PASSWORD=

# Supabase (not used)
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_PASSWORD=

# =============================================================================
# ENTORNO: DEV
# Perfil: mysql
# Use for: Daily development with MySQL/XAMPP
# =============================================================================
# SPRING_PROFILES_ACTIVE=mysql

# MySQL Configuration (XAMPP)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=tickets_db
# DB_USER=root
# DB_PASSWORD=

# Supabase (not used)
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_PASSWORD=

# =============================================================================
# ENTORNO: TEST
# Perfil: supabase
# Use for: Testing with Supabase
# =============================================================================
# SPRING_PROFILES_ACTIVE=supabase

# MySQL (not used)
# DB_HOST=
# DB_PORT=3306
# DB_NAME=
# DB_USER=
# DB_PASSWORD=

# Supabase Configuration (TEST)
# DB_HOST=db.xxxxxxxxxxxx.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-supabase-password

# =============================================================================
# ENTORNO: PROD
# Perfil: supabase (same profile as test, different values)
# Use for: Production delivery
# =============================================================================
# SPRING_PROFILES_ACTIVE=supabase

# MySQL (not used)
# DB_HOST=
# DB_PORT=3306
# DB_NAME=
# DB_USER=
# DB_PASSWORD=

# Supabase Configuration (PROD - different values!)
# DB_HOST=db.yyyyyyyyyyyy.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-prod-password